# gRPC-Relay environment variables
# Copy this file to .env and fill in the values.
# docker-compose.yml loads this file via env_file for the relay service.

# Relay identity
RELAY_ID=relay-001

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# Override config values via environment variables (config-rs convention)
# Format: RELAY__<section>__<subsection>__<key>

# MQTT broker address (overrides config/relay.yaml relay.mqtt.broker_address)
RELAY__MQTT__BROKER_ADDRESS=localhost:1883

# JWT secret for Controller authentication
# Generate a strong random secret: openssl rand -hex 32
RELAY__AUTH__JWT__HS256_SECRET=<generate-random-secret>

# TLS configuration (overrides config/relay.yaml relay.tls)
# RELAY__TLS__ENABLED=true
# RELAY__TLS__CERT_PATH=/etc/relay/tls/server.crt
# RELAY__TLS__KEY_PATH=/etc/relay/tls/server.key

# OTLP tracing endpoint
# OBSERVABILITY__TRACING__ENABLED=true
# OBSERVABILITY__TRACING__OTLP_ENDPOINT=http://jaeger:4317

# Grafana admin password (required by docker-compose)
# GRAFANA_ADMIN_PASSWORD=<set-strong-password>
