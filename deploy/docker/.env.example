# gRPC-Relay Docker deployment environment variables
# Copy to the repo root as .env and fill in the values.
# docker-compose.yml loads this file via env_file.

# Relay identity
RELAY_ID=relay-001

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# MQTT broker address (overrides config/relay.yaml relay.mqtt.broker_address)
RELAY__MQTT__BROKER_ADDRESS=mqtt:1883

# JWT secret for Controller authentication
# Generate: openssl rand -hex 32
RELAY__AUTH__JWT__HS256_SECRET=<generate-random-secret>

# TLS (set ENABLED=true and provide cert/key paths)
# RELAY__TLS__ENABLED=true
# RELAY__TLS__CERT_PATH=/etc/relay/tls/server.crt
# RELAY__TLS__KEY_PATH=/etc/relay/tls/server.key

# OTLP tracing endpoint (jaeger service in compose)
# OBSERVABILITY__TRACING__ENABLED=true
# OBSERVABILITY__TRACING__OTLP_ENDPOINT=http://jaeger:4317

# Grafana admin password (required)
GRAFANA_ADMIN_PASSWORD=<set-strong-password>
