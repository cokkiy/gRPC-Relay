# Bare-metal environment overrides for gRPC-Relay.
# Copy to /etc/grpc-relay/relay.env and adjust for the host.

RELAY_ID=relay-baremetal-001
RUST_LOG=info

# MQTT broker reachable from this host
RELAY__MQTT__BROKER_ADDRESS=127.0.0.1:1883

# Controller JWT secret
RELAY__AUTH__JWT__HS256_SECRET=<generate-random-secret>

# TLS certificate paths on the host
RELAY__TLS__ENABLED=false
RELAY__TLS__CERT_PATH=/etc/grpc-relay/tls/server.crt
RELAY__TLS__KEY_PATH=/etc/grpc-relay/tls/server.key

# Optional tracing endpoint
# OBSERVABILITY__TRACING__ENABLED=true
# OBSERVABILITY__TRACING__OTLP_ENDPOINT=http://127.0.0.1:4317
